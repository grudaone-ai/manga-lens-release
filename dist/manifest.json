{
  "manifest_version": 3,
  "name": "MangaLens",
  "version": "4.0.1",
  "description": "Pixiv manga translator using Pixiv HTML containers and Zhipu GLM-4.6V.",
  "permissions": [
    "activeTab",
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://www.pixiv.net/*",
    "https://i.pximg.net/*",
    "https://open.bigmodel.cn/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "pixiv_referer_rules",
        "enabled": true,
        "path": "rules/pixiv-referer.json"
      }
    ]
  },
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.pixiv.net/*"],
      "js": ["content-script.js"],
      "css": ["content-styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
